[Unit]
Description=Watchdog for restarting unhealthy docker containers
After=docker.service
Wants=docker.service
Requires=docker.socket
# Start rate-limit belongs in [Unit] (ignored in [Service] on systemd v229+).
StartLimitIntervalSec=60s
StartLimitBurst=3

[Service]
Type=notify
ExecStart=/opt/docker-watchdog/venv/bin/python /usr/local/bin/docker-watchdog.py
WorkingDirectory=/home/alex/humboldt
TimeoutStartSec=5s
RestartSec=600s
Restart=always

[Install]
WantedBy=multi-user.target
